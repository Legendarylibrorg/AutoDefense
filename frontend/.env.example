VITE_BACKEND_HTTP=http://localhost:8000
VITE_BACKEND_WS=ws://localhost:8000
# Sealed POST bodies: must match backend AUTODEFENSE_TRANSPORT_KEY_B64 (32-byte master → 3 HKDF subkeys). See docs/security.md#hkdf-parameters-backend-and-browser
VITE_TRANSPORT_SEAL_ENABLED=true
# Optional: leave empty and paste keys in the dashboard ("API session keys") so they are not baked into the bundle.
VITE_TRANSPORT_KEY_B64=
VITE_API_KEY=
