AUTODEFENSE_LOG_LEVEL=INFO
AUTODEFENSE_ENVIRONMENT=local
AUTODEFENSE_SELF_HEAL_ENABLED=true

# API key for authenticating dashboard and programmatic access.
# Auto-generated by scripts/start.sh if left empty.
AUTODEFENSE_API_KEY=

# HMAC key for scanner payload signing (shared between scanner + backend).
# Auto-generated by scripts/start.sh if left empty.
AUTODEFENSE_SCANNER_HMAC_KEY=

# Redis password (used by both Redis and backend).
AUTODEFENSE_REDIS_PASSWORD=

# Data encryption (at-rest in Redis, AES-256-GCM; on by default)
# Keys are auto-generated by scripts/start.sh if left empty.
AUTODEFENSE_DATA_ENCRYPTION_ENABLED=true
AUTODEFENSE_DATA_KEY_B64=

# Sealed transport (client->backend AES-256-GCM request encryption; on by default)
# Keys are auto-generated by scripts/start.sh if left empty.
AUTODEFENSE_TRANSPORT_SEAL_ENABLED=true
AUTODEFENSE_TRANSPORT_KEY_B64=

# CORS origins (comma-separated, change for production)
AUTODEFENSE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
